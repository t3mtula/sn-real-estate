# Supabase — ใส่ค่าตาม project ของ app นี้
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Auth — restrict ให้ login ได้เฉพาะ email โดเมนนี้ (เว้นว่างถ้าไม่ต้องการ)
VITE_AUTH_ALLOWED_DOMAIN=

# Sentry (option · error tracking · ฟรี 5K errors/mo) — เว้นว่าง = skip
VITE_SENTRY_DSN=

# App
VITE_APP_NAME=Yonghua App
VITE_APP_VERSION=0.1.0
